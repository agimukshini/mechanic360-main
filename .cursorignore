env/
/env

# Add directories or file patterns to ignore during indexing (e.g. foo/ or *.csv)
# =========================================================
# Cursor Ignore - Token/Context Cost Optimization
# Purpose: prevent Cursor from wasting context on generated,
# dependency, cache, media, logs, secrets, and deployment files.
# =========================================================


# -------------------------
# Dependencies
# -------------------------
node_modules/
frontend/node_modules/
backend/node_modules/
.pnp/
.pnp.js/
vendor/


# -------------------------
# Python / Django
# -------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.sqlite3
db.sqlite3
*.db
*.db-journal

.venv/
venv/
env/
ENV/
virtualenv/

*.egg-info/
.eggs/
pip-wheel-metadata/

.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
coverage.xml


# -------------------------
# Django generated/static/media
# -------------------------
staticfiles/
media/
uploads/
collected_static/
*/migrations/__pycache__/

# Optional:
# Ignore migrations if project is large and AI does not need DB history.
# Keep migrations visible when working on schema evolution.
# **/migrations/*.py


