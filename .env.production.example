# Production — copy to /opt/docker/mechanic360/.env before deploy
# Used with:
#   docker compose -f docker-compose.yml -f docker-compose.qnap.yml -f docker-compose.prod.yml up -d --build

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,backmechanic.managefleet.org,mechanic360.managefleet.org
CORS_ALLOWED_ORIGINS=https://mechanic360.managefleet.org
CSRF_TRUSTED_ORIGINS=https://mechanic360.managefleet.org,https://backmechanic.managefleet.org

POSTGRES_DB=mechanic360
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

FRONTEND_BASE_URL=https://mechanic360.managefleet.org

# --- SMTP (outbound email) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtppro.zoho.eu
EMAIL_PORT=465
EMAIL_USE_TLS=0
EMAIL_USE_SSL=1
EMAIL_HOST_USER=mekaniku360@scardustech.com
EMAIL_HOST_PASSWORD=change-me-mailbox-password
DEFAULT_FROM_EMAIL=Workshop360 <mekaniku360@scardustech.com>
SERVER_EMAIL=mekaniku360@scardustech.com
