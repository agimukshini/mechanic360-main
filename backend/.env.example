# Development environment configuration
# Copy this to .env and adjust for your local setup

# Django settings (required in production when DJANGO_DEBUG=0)
DJANGO_SECRET_KEY=dev-secret-key-change-in-production-12345678
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origins (comma-separated). Defaults to localhost:5173 if unset.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com

# Database (PostgreSQL)
POSTGRES_DB=mechanic360
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Storage — QNAP NAS bind mount in production (see working_scope/ARCHITECTURE.md)
# Dev: Docker volume media_data → /app/media
# Prod: mount QNAP share on host, bind to /app/media in backend container
# Optional: MEDIA_ROOT=/mnt/qnap/mechanic360-media

# Celery/Redis
CELERY_BROKER_URL=redis://localhost:6379/0

# Email (SMTP) — dev: omit EMAIL_BACKEND to log emails to console when DJANGO_DEBUG=1
# Zoho EU example (port 465 = SSL, not TLS):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtppro.zoho.eu
# EMAIL_PORT=465
# EMAIL_USE_TLS=0
# EMAIL_USE_SSL=1
# EMAIL_HOST_USER=mekaniku360@scardustech.com
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=Mekaniku360 <mekaniku360@scardustech.com>
# PLATFORM_CONTACT_EMAIL=mekaniku360@scardustech.com
# FRONTEND_BASE_URL=https://mekaniku360.com
